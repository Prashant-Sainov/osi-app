rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the current user's profile data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: check if caller is an admin
    function isAdmin() {
      return request.auth != null && getUserData().role == 'admin';
    }

    // Helper: check if caller belongs to a specific district
    function isDistrict(district) {
      return request.auth != null && getUserData().district == district;
    }

    // Users collection
    match /users/{userId} {
      // Users can read/write their own profile
      // Admins can read/write ANY profile
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Officers collection
    match /officers/{officerId} {
      // Admins can do anything
      // District users can only access their own district's officers
      allow read, write: if request.auth != null && (
        isAdmin() || 
        (resource == null ? request.resource.data.district : resource.data.district) == getUserData().district
      );
    }

    // Custom Lists collection
    match /customLists/{listId} {
      allow read, write: if request.auth != null && (
        isAdmin() || 
        (resource == null ? request.resource.data.district : resource.data.district) == getUserData().district
      );
    }

    // Districts collection
    match /districts/{districtId} {
      allow read: if request.auth != null;
      // Stats should only be updated by the system or Admins if necessary
      allow write: if isAdmin();
    }
  }
}
